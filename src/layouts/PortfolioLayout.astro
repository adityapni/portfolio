---
import Layout from './Layout.astro';
---

<Layout>
  <main class="portfolio-page">
    <article class="portfolio-content">
      <slot />
    </article>
  </main>
</Layout>

<style>
  .portfolio-page {
    min-height: 100%;
    padding: 2rem clamp(1rem, 3vw, 2rem) 4rem;
    background: #f7f7f7;
    color: #111827;
    font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .portfolio-content {
    max-width: 760px;
    margin: 0 auto;
  }

  .portfolio-content :global(h1),
  .portfolio-content :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .portfolio-content :global(p),
  .portfolio-content :global(ul) {
    line-height: 1.7;
  }

  .portfolio-content :global(img) {
    display: block;
    height: 30vh;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    margin: 1.25rem 0;
    border-radius: 0.75rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }
</style>
